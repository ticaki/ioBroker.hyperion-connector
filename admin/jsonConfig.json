{
	"i18n": true,
	"type": "panel",
	"items": {
        "getDevices": {
					"newLine": true,
					"type": "sendTo",
                    "defaultSendTo": "getDevices",
					"command": "getDevices",
					"jsonData": "{ \"date\": \"${data.devices}\"}",
					"label": "getDevices",
					"useNative": true,
					"variant": "outlined",
                    "disabled": "_changed",
					"showProcess" : true,
					"xs": 12,
					"sm": 12,
					"md": 12,
					"lg": 12,
                    "xl": 12
				},
        "devices":{
            "type": "table",
            "label": "devices",
            "items": [
                {
                    "type": "checkbox",
                    "attr": "enabled",
                    "title": "enabled",
                    "width": "5%",
                    "default": true
                },
                {
                    "type": "text",
                    "attr": "name",
                    "title": "ServerName",
                    "readOnly": true,
                    "disabled": "true"
                },
                {
                    "type": "select",
                    "attr": "protocol",
                    "title": "ServerProtocol", 
                    "validator": "data.ServerProtocol !== ''",
                    "validatorNoSaveOnError": true,  
                    "width": "5%",
                    "options": [
                        {
                            "label": "http://",
                            "value": "http:"
                        },
                        {
                            "label": "https://",
                            "value": "https:"
                        }
                    ],
                    "default": "http:"
                },
                {
                    "type": "text",
                    "attr": "ip",
                    "title": "ServerIP",
                    "validator": "data.ip !== ''",
                    "validatorNoSaveOnError": true 
                },
                {
                    "type": "number",
                    "attr": "port",
                    "title": "ServerPort",
                    "validator": "data.port>0 && data.port<65536",
                    "validatorNoSaveOnError": true,
                    "width": "7%",
                    "default": 8090
                },
                
                {
                    "type": "text",
                    "attr": "token",
                    "title": "Token",
                    "allowEmpty": true
                }
            ],
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12
        },
        "reconnectTime": {
            "type": "number",
            "label": "reconnectTime",
            "tooltip": "reconnectTime_tooltip",
            "min": 3,
            "default": 60,
            "xs": 12,
            "sm": 8,
            "md": 6,
            "lg": 4,
            "xl": 4
        },
        "_dataReductionHeader": {
            "type": "header",
            "text": "dataReductionHeader",
            "size": 4,
            "newLine": true
        },
        "_dataReductionHint": {
            "type": "staticText",
            "text": "dataReductionHint",
            "newLine": true
        },
        "enableSysinfo": {
            "type": "checkbox",
            "label": "enableSysinfo",
            "tooltip": "enableSysinfo_tooltip",
            "default": true,
            "newLine": true,
            "xs": 12,
            "sm": 6,
            "md": 6,
            "lg": 3,
            "xl": 3
        },
        "enableServerinfo": {
            "type": "checkbox",
            "label": "enableServerinfo",
            "tooltip": "enableServerinfo_tooltip",
            "default": true,
            "xs": 12,
            "sm": 6,
            "md": 6,
            "lg": 3,
            "xl": 3
        },
        "enableDescription": {
            "type": "checkbox",
            "label": "enableDescription",
            "tooltip": "enableDescription_tooltip",
            "default": true,
            "xs": 12,
            "sm": 6,
            "md": 6,
            "lg": 3,
            "xl": 3
        },
        "enableInstances": {
            "type": "checkbox",
            "label": "enableInstances",
            "tooltip": "enableInstances_tooltip",
            "default": true,
            "xs": 12,
            "sm": 6,
            "md": 6,
            "lg": 3,
            "xl": 3
        }
    }
}
